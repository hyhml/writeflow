# WriteFLow runtime config
# Copy this file to .env and fill one provider section.

# Option A: DeepSeek
WRITEFLOW_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Option B: MiniMax
# WRITEFLOW_PROVIDER=minimax
# MINIMAX_API_KEY=your-minimax-key
# MINIMAX_MODEL=MiniMax-M1
# MINIMAX_BASE_URL=https://api.minimax.chat/v1

# Option C: Any OpenAI-compatible service
# WRITEFLOW_PROVIDER=openai_compatible
# WRITEFLOW_API_KEY=your-api-key
# WRITEFLOW_MODEL=your-model-name
# WRITEFLOW_BASE_URL=https://your-provider.example/v1

# Option D: Anthropic
# WRITEFLOW_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key
# CLAUDE_MODEL=claude-sonnet-4-5

# Generation settings
WRITEFLOW_MAX_TOKENS=8192
WRITEFLOW_TEMPERATURE=0.7
WRITEFLOW_TIMEOUT=120
WRITEFLOW_MAX_RETRIES=3

# Workflow settings
WRITEFLOW_MAX_ROUNDS=5
WRITEFLOW_MIN_ROUNDS=2

# Optional search abstraction for local voices.
# v0.2.8 defaults to none and never fabricates quotes.
WRITEFLOW_SEARCH_PROVIDER=none
# TAVILY_API_KEY=
# SERPAPI_API_KEY=

# Depth Gate settings
QUALITY_DEPTH_THRESHOLD=5.0
